# =============================================================================
# FRONTEND — PRODUCTION ENVIRONMENT TEMPLATE
# Set these in Vercel → Project Settings → Environment Variables
# Or copy to .env.production (gitignored) for manual builds
# =============================================================================

# Full public URL of your Render backend — NO trailing slash
# Example: https://nserve-quiz-api.onrender.com
VITE_API_URL=https://YOUR-RENDER-SERVICE.onrender.com

# Same OAuth 2.0 Web Client ID as backend GOOGLE_CLIENT_ID
# Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
