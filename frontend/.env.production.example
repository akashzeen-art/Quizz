# Production build (quiz.play365game.com or any static host)
# -----------------------------------------------------------------------------
# Copy: cp .env.production.example .env.production
# Or set VITE_API_URL in your host (Vercel / Netlify / Cloudflare) — same value.
#
# This must be the PUBLIC URL of your Spring Boot API (e.g. Render), with NO trailing slash.
# Example: https://your-service-name.onrender.com
#
# The backend Render env CORS_ORIGINS must include your game site origin, e.g.:
#   https://quiz.play365game.com,http://quiz.play365game.com
#
VITE_API_URL=https://YOUR-API-HOST.onrender.com
