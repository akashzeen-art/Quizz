# =============================================================================
# BACKEND — ENVIRONMENT VARIABLES TEMPLATE
# Copy to .env: cp .env.example .env
# Fill in your real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# MongoDB Atlas: Database → Connect → Drivers
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/skill_quiz?retryWrites=true&w=majority&serverSelectionTimeoutMS=60000

# -----------------------------------------------------------------------------
# CORS — comma-separated origins, no spaces
# Local dev:   http://localhost:5173
# Production:  https://quiz.play365game.com,http://quiz.play365game.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# JWT — minimum 32 characters
# Generate: openssl rand -base64 48
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars!!
JWT_EXPIRATION_MS=86400000

# -----------------------------------------------------------------------------
# ADMIN SEED (only used on first boot when admins collection is empty)
# -----------------------------------------------------------------------------
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_ACTIVE_MINUTES=15

# -----------------------------------------------------------------------------
# GOOGLE SIGN-IN
# Must match VITE_GOOGLE_CLIENT_ID on the frontend
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Web Client
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# TWILIO OTP
# Twilio Console → Account Info + Verify Service SID
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set true + mock code for local dev to skip real SMS
TWILIO_MOCK_ENABLED=false
TWILIO_MOCK_CODE=123456

# -----------------------------------------------------------------------------
# WALLET
# -----------------------------------------------------------------------------
WALLET_QUIZ_START_COST=10
WALLET_ENTITLEMENT_HOURS=24

# -----------------------------------------------------------------------------
# FACE SERVICE (Python FastAPI — run separately)
# -----------------------------------------------------------------------------
FACE_SERVICE_URL=http://localhost:8001
