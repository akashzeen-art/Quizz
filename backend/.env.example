# =============================================================================
# Local development
# Copy to .env (gitignored): cp .env.example .env
# backend/run-dev.sh sources .env before mvn.
# =============================================================================

# MongoDB Atlas: Database → Connect → Drivers (replace USER / PASSWORD / CLUSTER)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER_HOST/skill_quiz?retryWrites=true&w=majority&serverSelectionTimeoutMS=60000

# Comma-separated browser origins allowed to call the API (no spaces).
# Local Vite dev:
CORS_ORIGINS=http://localhost:5173

# Google Sign-In (OAuth 2.0 Web Client ID from Google Cloud Console → APIs → Credentials).
# Must match VITE_GOOGLE_CLIENT_ID on the frontend.
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# --- Admin JWT (required for /admin APIs) — min 32 characters ---
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars!!
# JWT_EXPIRATION_MS=86400000

# --- First-time admin seed (only if admins collection is empty) ---
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# --- Optional ---
# ADMIN_ACTIVE_MINUTES=15

# =============================================================================
# Production (e.g. Render Web Service — set these in the Render dashboard)
# Website: https://quiz.play365game.com  (include http + https if you use both)
# =============================================================================
#
# MONGODB_URI=<same as above, from Atlas>
#
# Must list your live game site so the browser can call the API (comma-separated, no spaces):
# CORS_ORIGINS=https://quiz.play365game.com,http://quiz.play365game.com
#
# If you still test local frontend against production API, append:
#   ,http://localhost:5173
#
# JWT_SECRET=<strong secret, not the dev default>
#
# Optional: ADMIN_SEED_EMAIL, ADMIN_SEED_PASSWORD, JWT_EXPIRATION_MS, ADMIN_ACTIVE_MINUTES
#
# Render injects PORT automatically; app uses server.port=${PORT:8080} in application.yml.
