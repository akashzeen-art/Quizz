# Copy to .env (gitignored) and adjust. backend/run-dev.sh sources .env before mvn.
#
# Production: set a long random JWT_SECRET, set ADMIN_SEED_EMAIL / ADMIN_SEED_PASSWORD for first
# deploy if you do not want the defaults, and point CORS_ORIGINS at your real origin.
#
# MongoDB — Atlas: Database → Connect → Drivers
# If you see SSLException / "fatal alert: internal_error" to Atlas:
# - Use JDK 21 LTS (not JDK 25+). macOS: brew install openjdk@21, or run ./run-dev.sh (prefers Java 21).
# - This project enforces JDK 21–24 in pom.xml; mvn compile fails on JDK 25+ by design.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER_HOST/skill_quiz?retryWrites=true&w=majority&serverSelectionTimeoutMS=60000

CORS_ORIGINS=http://localhost:5173

# --- Admin JWT (required for /admin APIs) ---
# At least 32 characters. Generate e.g.: openssl rand -base64 48
JWT_SECRET=nserve-quiz-admin-jwt-secret-key-min-32-chars!!
# JWT_EXPIRATION_MS=86400000

# --- First-time admin seed (only if admins collection is empty) ---
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=Admin@123

# --- Optional ---
# ADMIN_ACTIVE_MINUTES=15
